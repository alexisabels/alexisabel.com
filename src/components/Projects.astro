---
import FirebaseIcon from "./icons/FirebaseIcon.astro";
import GithubIcon from "./icons/GithubIcon.astro";
import JSIcon from "./icons/JSIcon.astro";
import JavaIcon from "./icons/JavaIcon.astro";
import LinkIcon from "./icons/LinkIcon.astro";
import MaterialUiIcon from "./icons/MaterialUiIcon.astro";
import MySQLIcon from "./icons/MySQLIcon.astro";
import ReactIcon from "./icons/ReactIcon.astro";
import SQLIcon from "./icons/SQLIcon.astro";
import TailwindIcon from "./icons/TailwindIcon.astro";
import SpringIcon from "./icons/SpringIcon.astro";
import NextJSIcon from "./icons/NextJSIcon.astro";
import TSIcon from "./icons/TSIcon.astro";

const TAGS = {
  REACT: { name: "React", icon: ReactIcon },
  FIRE: { name: "Firebase", icon: FirebaseIcon },
  MUI: { name: "Material UI", icon: MaterialUiIcon },
  JS: { name: "JavaScript", icon: JSIcon },
  JAVA: { name: "Java", icon: JavaIcon },
  SQL: { name: "SQL", icon: SQLIcon },
  MYSQL: { name: "MySQL", icon: MySQLIcon },
  TAILWIND: { name: "Tailwind", icon: TailwindIcon },
  SPRING: { name: "Spring", icon: SpringIcon },
  NEXT: { name: "Next.js", icon: NextJSIcon },
  TS: { name: "TypeScript", icon: TSIcon },
};

const PROJECTS = [
  {
    title: "Excertia",
    description:
      "Plataforma SaaS para registro y búsqueda de empresas con sistemas de gestión certificados. Stack: Next.js 15, React 19, Supabase, Stripe, Resend.",
    image: "/excertia.png",
    tags: [TAGS.NEXT, TAGS.REACT],
    status: "en desarrollo",
  },
  {
    title: "Plataforma de cumplimiento normativo",
    description:
      "Sistema interno para una organización con varios centros. Descompone las normativas que le aplican en obligaciones concretas, las asigna a los centros que correspondan, gestiona las auditorías asociadas y permite consultar el estado de cumplimiento por centro o de toda la organización. React, TypeScript, Material UI, Supabase.",
    image: "/cumplimiento.png",
    tags: [TAGS.REACT, TAGS.TS],
    status: "privado",
  },
  {
    title: "AudSys",
    description:
      "Aplicación para ayudar a pequeñas empresas a controlar sus procesos de calidad. Organiza auditorías, registra hallazgos, asigna responsables y hace seguimiento de acciones.",
    github: "https://github.com/alexisabels/audsys",
    image: "/audsys.jpg",
    tags: [TAGS.JAVA, TAGS.MYSQL, TAGS.SPRING],
  },
  {
    title: "Waving Social",
    description:
      "Red social con React: publicaciones, timelines, comentarios, perfiles y sistema de seguimiento. Autenticación y base de datos en Firebase.",
    github: "https://github.com/alexisabels/waving",
    link: "https://wavingsocial.web.app/",
    image: "/waving.png",
    tags: [TAGS.REACT, TAGS.FIRE, TAGS.MUI],
  },
  {
    title: "InvoicePRO",
    description:
      "Sistema de gestión empresarial con JSP, JPA y JDBC. Administra inventarios, clientes, usuarios y ventas sobre MySQL.",
    github: "https://github.com/alexisabels/InvoicePro",
    image: "/invoice.png",
    tags: [TAGS.JAVA, TAGS.MYSQL],
    status: "en desarrollo",
  },
  {
    title: "Gasolineras España",
    description:
      "Busca gasolineras por municipio y consulta precios de combustible y horarios de apertura en tiempo real.",
    github: "https://github.com/alexisabels/info-carburantes",
    link: "https://carburantes.alexisabel.com/",
    image: "/gasolineras.png",
    tags: [TAGS.REACT, TAGS.JS],
  },
  {
    title: "CineKino",
    description:
      "Seguimiento de películas vistas, reseñas y red de usuarios. React + Firebase para auth y base de datos.",
    github: "https://github.com/alexisabels/cinekino",
    link: "https://cinekino.alexisabel.com/",
    image: "/cinekino.png",
    tags: [TAGS.REACT, TAGS.FIRE, TAGS.TAILWIND],
    status: "en desarrollo",
  },
  {
    title: "Rijksgalerij",
    description:
      "Explora y busca en la colección del Rijksmuseum de Ámsterdam a través de su API oficial.",
    github: "https://github.com/alexisabels/rijksgalerij",
    link: "https://rijksmuseum.alexisabel.com/",
    image: "/rijksgalerij.png",
    tags: [TAGS.REACT, TAGS.MUI],
  },
  {
    title: "Porra LaLiga",
    description:
      "Consulta resultados de La Liga y apuestas ficticias. JSP, JPA, JSTL, Ajax y Oracle DB.",
    github: "https://github.com/alexisabels/LALIGA",
    image: "/laliga.png",
    tags: [TAGS.JAVA, TAGS.SQL],
  },
  {
    title: "Biblioteca JSP",
    description:
      "Gestión de biblioteca con JSP y acceso a Oracle vía JDBC. Incluye sistema de penalización por retrasos.",
    github: "https://github.com/alexisabels/biblioteca-jsp",
    image: "/biblioteca.png",
    tags: [TAGS.JAVA, TAGS.SQL],
  },
  {
    title: "The Cocktail DB",
    description:
      "SPA sobre la API de TheCocktailDB. Recetas, ingredientes y búsqueda por nombre o ingrediente.",
    github: "https://github.com/alexisabels/thecocktaildb",
    image: "/cocktail.png",
    link: "https://cocktail.alexisabel.com/",
    tags: [TAGS.REACT],
  },
];

const initial = PROJECTS.slice(0, 4);
const rest = PROJECTS.slice(4);
---

<div class="relative" id="projects-section">
  <!-- lightbox dialog -->
  <dialog
    id="image-dialog"
    class="bg-transparent p-0 max-w-[95vw] max-h-[95vh] backdrop:bg-ink/85 backdrop:backdrop-blur-sm m-auto"
  >
    <div class="relative">
      <img
        id="image-dialog-img"
        alt=""
        class="block max-w-[95vw] max-h-[95vh] object-contain border border-hairline bg-paper cursor-zoom-out"
      />
      <button
        id="image-dialog-close"
        type="button"
        aria-label="Cerrar"
        class="absolute top-3 right-3 size-9 flex items-center justify-center bg-paper/90 backdrop-blur-sm border border-hairline text-ink hover:text-accent transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-4"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </dialog>

  <!-- Project list -->
  <ol id="projects-list" class="flex flex-col border-t border-hairline">
    {
      initial.map((project) => (
        <li
          class="project-row group grid grid-cols-12 gap-4 md:gap-8 py-6 md:py-8 border-b border-hairline transition-colors duration-200 hover:bg-paper-raised/50"
          data-image={project.image}
        >
          <button
            type="button"
            aria-label={`Ampliar imagen de ${project.title}`}
            data-image={project.image}
            data-cursor-label="Ver"
            class="open-image col-span-12 md:col-span-5 block cursor-zoom-in"
          >
            <img
              src={project.image}
              alt={project.title}
              loading="lazy"
              class="w-full aspect-[16/10] object-cover object-top border border-hairline transition-opacity hover:opacity-90"
            />
          </button>

          <div class="col-span-12 md:col-span-7 flex flex-col gap-4 md:gap-5">
            <div class="flex flex-wrap items-baseline gap-3">
              <h3 class="font-display font-semibold text-ink tracking-tight2 leading-[1] text-[clamp(1.5rem,3.5vw,2.5rem)] group-hover:text-accent transition-colors">
                {project.title}
              </h3>
              {project.status && (
                <span class="text-accent text-xs uppercase tracking-label font-mono">
                  {project.status}
                </span>
              )}
            </div>

            <p class="text-ink-muted text-sm md:text-base leading-[1.55] max-w-2xl">
              {project.description}
            </p>

            <div class="flex flex-wrap items-center gap-x-4 gap-y-1.5">
              {project.tags.map((tag) => (
                <span class="inline-flex items-center gap-1.5 text-ink-muted text-xs md:text-sm">
                  <tag.icon class="size-3.5" />
                  <span>{tag.name}</span>
                </span>
              ))}
            </div>

            <div class="flex items-center gap-5 md:mt-auto pt-1">
              {project.github && (
                <a
                  href={project.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Código"
                  class="text-ink-muted hover:text-accent transition-colors"
                >
                  <GithubIcon class="size-5" />
                </a>
              )}
              {project.link && (
                <a
                  href={project.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Visitar"
                  class="text-ink-muted hover:text-accent transition-colors"
                >
                  <LinkIcon class="size-5" />
                </a>
              )}
            </div>
          </div>
        </li>
      ))
    }
  </ol>

  <ol id="more-projects" class="hidden flex-col border-b border-hairline">
    {
      rest.map((project) => (
        <li
          class="project-row group grid grid-cols-12 gap-4 md:gap-8 py-6 md:py-8 border-b border-hairline last:border-b-0 transition-colors duration-200 hover:bg-paper-raised/50"
          data-image={project.image}
        >
          <button
            type="button"
            aria-label={`Ampliar imagen de ${project.title}`}
            data-image={project.image}
            data-cursor-label="Ver"
            class="open-image col-span-12 md:col-span-5 block cursor-zoom-in"
          >
            <img
              src={project.image}
              alt={project.title}
              loading="lazy"
              class="w-full aspect-[16/10] object-cover object-top border border-hairline transition-opacity hover:opacity-90"
            />
          </button>

          <div class="col-span-12 md:col-span-7 flex flex-col gap-4 md:gap-5">
            <div class="flex flex-wrap items-baseline gap-3">
              <h3 class="font-display font-semibold text-ink tracking-tight2 leading-[1] text-[clamp(1.5rem,3.5vw,2.5rem)] group-hover:text-accent transition-colors">
                {project.title}
              </h3>
              {project.status && (
                <span class="text-accent text-xs uppercase tracking-label font-mono">
                  {project.status}
                </span>
              )}
            </div>

            <p class="text-ink-muted text-sm md:text-base leading-[1.55] max-w-2xl">
              {project.description}
            </p>

            <div class="flex flex-wrap items-center gap-x-4 gap-y-1.5">
              {project.tags.map((tag) => (
                <span class="inline-flex items-center gap-1.5 text-ink-muted text-xs md:text-sm">
                  <tag.icon class="size-3.5" />
                  <span>{tag.name}</span>
                </span>
              ))}
            </div>

            <div class="flex items-center gap-5 md:mt-auto pt-1">
              {project.github && (
                <a
                  href={project.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Código"
                  class="text-ink-muted hover:text-accent transition-colors"
                >
                  <GithubIcon class="size-5" />
                </a>
              )}
              {project.link && (
                <a
                  href={project.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Visitar"
                  class="text-ink-muted hover:text-accent transition-colors"
                >
                  <LinkIcon class="size-5" />
                </a>
              )}
            </div>
          </div>
        </li>
      ))
    }
  </ol>

  <div class="mt-8 flex items-center gap-4 flex-wrap">
    <button
      id="view-more-btn"
      class="inline-flex items-center gap-3 text-ink hover:text-accent transition-colors text-base font-medium"
      data-more-label="Ver más"
      data-less-label="Ver menos"
    >
      <span id="view-more-label">Ver más</span>
      <span
        id="view-more-arrow"
        class="inline-block transition-transform duration-300"
        aria-hidden="true">→</span
      >
    </button>
    <span class="text-ink-muted text-sm">
      o todo en
      <a
        href="https://github.com/alexisabels"
        target="_blank"
        rel="noopener noreferrer"
        class="text-ink hover:text-accent underline decoration-hairline underline-offset-4 hover:decoration-accent transition-colors"
        >GitHub</a
      >
    </span>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // Lightbox
    const dialog = document.getElementById(
      "image-dialog"
    ) as HTMLDialogElement | null;
    const dialogImg = document.getElementById(
      "image-dialog-img"
    ) as HTMLImageElement | null;
    const closeBtn = document.getElementById("image-dialog-close");

    const bindOpen = (root: Document | HTMLElement) => {
      root.querySelectorAll<HTMLButtonElement>(".open-image").forEach((btn) => {
        if (btn.dataset.bound === "1") return;
        btn.dataset.bound = "1";
        btn.addEventListener("click", () => {
          const src = btn.dataset.image;
          if (src && dialogImg && dialog) {
            dialogImg.src = src;
            dialog.showModal();
          }
        });
      });
    };
    bindOpen(document);

    closeBtn?.addEventListener("click", () => dialog?.close());
    dialogImg?.addEventListener("click", () => dialog?.close());
    dialog?.addEventListener("click", (e) => {
      if (e.target === dialog) dialog.close();
    });

    const btn = document.getElementById("view-more-btn");
    const more = document.getElementById("more-projects");
    const label = document.getElementById("view-more-label");
    const arrow = document.getElementById("view-more-arrow");
    if (btn && more && label && arrow) {
      btn.addEventListener("click", () => {
        const isHidden = more.classList.contains("hidden");
        more.classList.toggle("hidden", !isHidden);
        more.classList.toggle("flex", isHidden);

        if (isHidden) {
          bindOpen(more);
        }

        label.textContent = isHidden
          ? (btn as HTMLElement).dataset.lessLabel || "Ver menos"
          : (btn as HTMLElement).dataset.moreLabel || "Ver más";
        arrow.style.transform = isHidden ? "rotate(90deg)" : "rotate(0deg)";
      });
    }
  });
</script>
