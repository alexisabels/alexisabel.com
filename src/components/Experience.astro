---
const JOBS = [
  {
    company: "Agencia de Transformación Digital de Castilla-La Mancha",
    role: "Software Developer",
    location: "Toledo",
    period: "dic 2025 — hoy",
    description:
      "Desarrollo de soluciones de administración electrónica para la Dirección General de Digitalización e Inteligencia Artificial de Castilla-La Mancha. Diseño e integro agentes de IA en el ciclo de vida del desarrollo.",
    href: "https://agenciatd.castillalamancha.es/",
    hrefLabel: "agenciatd.castillalamancha.es",
    logo: "https://www.castillalamancha.es/sites/default/files/logo-corporativo-JCCM-web.png",
    logoDark:
      "https://agenciatd.castillalamancha.es/themes/contrib/hjccm/logo-jccm-white.svg",
    logoAlt: "Logo Junta de Comunidades de Castilla-La Mancha",
  },
  {
    company: "Delógica (Santander US)",
    role: "Junior Software Developer",
    location: "Madrid",
    period: "oct 2025 — dic 2025",
    description:
      "Desarrollador Java/Spring para Banco Santander USA.",
    href: "https://www.delogica.com/",
    hrefLabel: "delogica.com",
    logo: "https://delogica.com/wp-content/uploads/2023/07/logo-delogica-header.png",
    logoAlt: "Logo Delógica",
    lightShadow: true,
  },
  {
    company: "Externa Ingenieros Consultores",
    role: "Responsable de desarrollo · Gestión de proyectos",
    location: "Toledo",
    period: "abr 2022 — hoy",
    description:
      "Colaboración en procesos internos de consultoría, gestión documental y seguimiento de proyectos. Desarrollo de una plataforma de cumplimiento normativo utilizada por múltiples empresas, así como de sistemas internos relacionados con auditorías y gestión. Participación en el desarrollo del portal Excertia, una plataforma que conecta empresas con sistemas de gestión certificados (calidad, medio ambiente, seguridad laboral) con clientes que buscan proveedores certificados.",
    href: "https://www.externaconsultores.com/",
    hrefLabel: "externaconsultores.com",
    logo: "https://www.externaconsultores.com/s/misc/logo.jpg?t=1774319908",
    logoAlt: "Logo Externa Ingenieros Consultores",
  },
  {
    company: "Mutuamad Motor Network (Aurgi & Motortown)",
    role: "Frontend Developer",
    location: "Madrid",
    period: "abr 2024 — jun 2024",
    description:
      "Formé parte del equipo de frontend. Trabajé en la mejora de componentes de la aplicación y fui responsable del 98% del coverage de pruebas en React con React Testing Library y Jest.",
    href: "https://www.aurgi.com/",
    hrefLabel: "aurgi.com",
    logo: "/aurgi.png",
    logoAlt: "Logo Aurgi",
  },
];
---

<ol class="flex flex-col border-t border-hairline">
  {
    JOBS.map((job) => (
      <li class="grid grid-cols-12 gap-4 md:gap-8 py-10 md:py-12 border-b border-hairline">
        <div class="col-span-12 md:col-span-3 flex md:flex-col gap-4 md:gap-4 items-start">
          <div class="flex items-center justify-start h-12 md:h-14 w-32 md:w-40 shrink-0">
            <img
              src={job.logo}
              alt={job.logoAlt}
              loading="lazy"
              class:list={[
                "max-h-full max-w-full object-contain object-left opacity-85 block dark:hidden",
                job.lightShadow && "logo-light-outline",
              ]}
            />
            <img
              src={job.logoDark || job.logo}
              alt={job.logoAlt}
              loading="lazy"
              class="max-h-full max-w-full object-contain object-left opacity-90 hidden dark:block"
            />
          </div>
          <div class="flex flex-col gap-0.5 md:mt-2">
            <span class="text-ink text-sm font-mono tabular">{job.period}</span>
            <span class="text-ink-muted text-sm">{job.location}</span>
          </div>
        </div>

        <div class="col-span-12 md:col-span-9 flex flex-col gap-4">
          <div>
            <h3 class="text-ink font-semibold text-2xl md:text-3xl leading-[1.1] tracking-tight2">
              {job.company}
            </h3>
            <p class="text-ink-muted text-base mt-1.5">{job.role}</p>
          </div>

          <p class="text-ink text-base md:text-lg leading-[1.6] max-w-2xl">
            {job.description}
          </p>

          <a
            href={job.href}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-accent text-sm hover:underline underline-offset-4 w-fit font-mono"
          >
            <span>{job.hrefLabel}</span>
            <span aria-hidden="true">↗</span>
          </a>
        </div>
      </li>
    ))
  }
</ol>

<style>
  .logo-light-outline {
    filter:
      drop-shadow(0 0 0.5px rgba(0, 0, 0, 0.55))
      drop-shadow(0 0 1.5px rgba(0, 0, 0, 0.35));
  }
</style>
