---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<div class="flex items-center gap-3 md:gap-4 mb-10 md:mb-14">
  <span
    class="inline-block size-3 md:size-3.5 bg-accent shrink-0 translate-y-[0.55em] md:translate-y-[0.75em]"
    aria-hidden="true"></span>
  <h2
    class="font-display text-ink font-semibold tracking-tight2 leading-[0.95] text-[clamp(2.25rem,5.5vw,4.25rem)]"
  >
    {title}
  </h2>
</div>
