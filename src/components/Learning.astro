---
import NextJSIcon from "./icons/NextJSIcon.astro";
import ElectronIcon from "./icons/ElectronIcon.astro";
import TSIcon from "./icons/TSIcon.astro";
import ReactNativeIcon from "./icons/ReactNativeIcon.astro";
import NodeIcon from "./icons/NodeIcon.astro";
import AngularIcon from "./icons/AngularIcon.astro";

const SKILLS = [
  { name: "Angular 19", icon: AngularIcon, url: "https://www.angular.io/" },
  { name: "TypeScript", icon: TSIcon, url: "https://www.typescriptlang.org/" },
  { name: "Node.js", icon: NodeIcon, url: "https://nodejs.org/" },
  { name: "Next.js", icon: NextJSIcon, url: "https://nextjs.org/" },
  { name: "Electron", icon: ElectronIcon, url: "https://www.electronjs.org/" },
  {
    name: "React Native",
    icon: ReactNativeIcon,
    url: "https://reactnative.dev/",
  },
];
---

<ul class="flex flex-wrap gap-x-3 gap-y-3">
  {
    SKILLS.map((skill) => (
      <li>
        <a
          href={skill.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-3 px-4 py-3 border border-hairline hover:border-accent transition-colors"
        >
          <skill.icon class="size-5" />
          <span class="text-ink text-base font-medium group-hover:text-accent transition-colors">
            {skill.name}
          </span>
        </a>
      </li>
    ))
  }
</ul>
