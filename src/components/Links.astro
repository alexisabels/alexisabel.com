---
import CVIcon from "./icons/CVIcon.astro";
import GithubIcon from "./icons/GithubIcon.astro";
import LinkedInIcon from "./icons/LinkedInIcon.astro";
import MailIcon from "./icons/MailIcon.astro";

interface Props {
  links: Array<{ href: string; icon: string; alt: string }>;
}

const { links } = Astro.props;

const icons: { [key: string]: (_props: Record<string, any>) => any } = {
  GithubIcon: GithubIcon,
  LinkedInIcon: LinkedInIcon,
  MailIcon: MailIcon,
  CVIcon: CVIcon,
};
---

<nav
  class="flex flex-wrap items-center gap-5 md:gap-7"
  aria-label="Enlaces de contacto"
>
  {
    links.map((link) => {
      const IconComponent = icons[link.icon];
      return (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={link.alt}
          class="group inline-flex items-center gap-2 text-ink hover:text-accent transition-colors"
        >
          <IconComponent class="size-5" />
          <span class="text-base">{link.alt}</span>
        </a>
      );
    })
  }
</nav>
