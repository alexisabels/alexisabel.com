<span class="typed-element font-display text-ink-muted"></span>

<script>
  import Typed from "typed.js";

  document.addEventListener("DOMContentLoaded", function () {
    new Typed(".typed-element", {
      strings: [
        "Desarrollo aplicaciones y servicios web.",
        "Integro herramientas de IA en el proceso.",
      ],
      typeSpeed: 42,
      backSpeed: 22,
      backDelay: 2400,
      loop: true,
      smartBackspace: true,
    });
  });
</script>

<style is:global>
  .typed-cursor {
    color: rgb(var(--accent));
    opacity: 0.9;
  }
</style>
