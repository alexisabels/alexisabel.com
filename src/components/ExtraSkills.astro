---
import AzureIcon from "./icons/AzureIcon.astro";
import BootstrapIcon from "./icons/BootstrapIcon.astro";
import CSSIcon from "./icons/CSSIcon.astro";
import FigmaIcon from "./icons/FigmaIcon.astro";
import GitlabIcon from "./icons/GitlabIcon.astro";
import OracleIcon from "./icons/OracleIcon.astro";
import TailwindIcon from "./icons/TailwindIcon.astro";
import AWSIcon from "./icons/AWSIcon.astro";
import MaterialIcon from "./icons/MaterialUiIcon.astro";
import JestIcon from "./icons/JestIcon.astro";
import MySQLIcon from "./icons/MySQLIcon.astro";

const SKILLS = [
  { name: "Gitlab", icon: GitlabIcon, url: "https://about.gitlab.com/" },
  { name: "Azure", icon: AzureIcon, url: "https://azure.microsoft.com/" },
  { name: "AWS", icon: AWSIcon, url: "https://aws.amazon.com/" },
  { name: "Oracle OCI", icon: OracleIcon, url: "https://www.oracle.com/cloud/" },
  { name: "MySQL", icon: MySQLIcon, url: "https://www.mysql.com/" },
  { name: "Tailwind", icon: TailwindIcon, url: "https://tailwindcss.com/" },
  { name: "Material UI", icon: MaterialIcon, url: "https://mui.com/" },
  { name: "Bootstrap", icon: BootstrapIcon, url: "https://getbootstrap.com/" },
  { name: "CSS", icon: CSSIcon, url: "https://developer.mozilla.org/en-US/docs/Web/CSS" },
  { name: "Figma", icon: FigmaIcon, url: "https://www.figma.com/" },
  { name: "Jest", icon: JestIcon, url: "https://jestjs.io/" },
];
---

<ul class="flex flex-wrap gap-x-3 gap-y-3">
  {
    SKILLS.map((skill) => (
      <li>
        <a
          href={skill.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-2.5 px-3 py-2 border border-hairline hover:border-accent transition-colors"
        >
          <skill.icon class="size-4" />
          <span class="text-ink text-sm md:text-base font-medium group-hover:text-accent transition-colors">
            {skill.name}
          </span>
        </a>
      </li>
    ))
  }
</ul>
