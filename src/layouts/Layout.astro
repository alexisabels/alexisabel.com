---
import SpeedInsights from "@vercel/speed-insights/astro";
import Cursor from "../components/Cursor.astro";
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "Desarrollo aplicaciones y servicios, cuidando que sean fáciles de usar y mantener, integrando herramientas de inteligencia artificial en el proceso de desarrollo.",
  image = "/nueva.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(image, Astro.site).toString();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="Alejandro Isabel, AI Software Engineer, ingeniero de software IA, desarrollador software, Toledo, Java, Spring, Spring Boot, React, Angular, TypeScript, agentes IA, LLM, Claude Code"
    />
    <meta name="author" content="Alejandro Isabel" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,300..800&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Alejandro Isabel" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        name: "Alejandro Isabel",
        alternateName: "Alex Isabel",
        url: "https://alexisabel.com",
        image: ogImage,
        jobTitle: "AI Software Engineer",
        description,
        address: {
          "@type": "PostalAddress",
          addressLocality: "Toledo",
          addressCountry: "ES",
        },
        knowsAbout: [
          "Artificial Intelligence",
          "Large Language Models",
          "AI Agents",
          "Java",
          "Spring",
          "Spring Boot",
          "React",
          "Angular",
          "TypeScript",
          "JavaScript",
          "SQL",
          "Software Engineering",
        ],
        sameAs: [
          "https://github.com/alexisabels",
          "https://linkedin.com/in/alexisabel",
        ],
      })}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: "Alejandro Isabel",
        url: "https://alexisabel.com",
        inLanguage: "es-ES",
        author: {
          "@type": "Person",
          name: "Alejandro Isabel",
        },
      })}
    />

    <script src="/node_modules/flowbite/dist/flowbite.js" is:client></script>
    <title>{title}</title>
  </head>
  <body>
    <Cursor />
    <slot />
  </body>
  <SpeedInsights />
</html>
<style is:global>
  :root {
    --ink: 14 14 14;
    --ink-muted: 110 110 110;
    --paper: 247 245 240;
    --paper-raised: 240 237 230;
    --accent: 15 120 80;
    --cursor-stroke: 14 14 14;
  }
  .dark {
    --ink: 237 234 227;
    --ink-muted: 135 135 135;
    --paper: 16 14 11;
    --paper-raised: 24 21 17;
    --accent: 120 180 150;
    --cursor-stroke: 16 14 11;
  }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
  }

  html,
  body {
    margin: 0;
    padding: 0;
  }

  body {
    background-color: rgb(var(--paper));
    color: rgb(var(--ink));
    font-family:
      "Bricolage Grotesque",
      ui-sans-serif,
      system-ui,
      sans-serif;
    font-optical-sizing: auto;
    font-weight: 400;
    font-size: 17px;
    line-height: 1.5;
    min-height: 100vh;
    padding: 0 1.25rem;
    overflow-x: hidden;
  }

  .tabular {
    font-variant-numeric: tabular-nums;
  }

  @media (min-width: 768px) {
    body {
      padding: 0 2.5rem;
    }
  }

  ::selection {
    background: rgb(var(--accent));
    color: rgb(var(--paper));
  }

  body::-webkit-scrollbar {
    width: 0;
  }

  /* paper grain — sutil, ambos modos via overlay */
  body::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 200 200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/></filter><rect width='200' height='200' filter='url(%23n)' opacity='0.55'/></svg>");
    background-size: 200px 200px;
    background-repeat: repeat;
    opacity: 0.16;
    mix-blend-mode: overlay;
  }
  html.dark body::before {
    opacity: 0.24;
  }

  /* one orchestrated load */
  @keyframes slide-up {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .slide-up {
    animation: slide-up 700ms cubic-bezier(0.2, 0.7, 0.1, 1) both;
  }
  .delay-1 { animation-delay: 100ms; }
  .delay-2 { animation-delay: 200ms; }
  .delay-3 { animation-delay: 300ms; }
  .delay-4 { animation-delay: 400ms; }

  /* in-view fade for sections */
  .in-view {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 600ms cubic-bezier(0.2, 0.7, 0.1, 1),
      transform 600ms cubic-bezier(0.2, 0.7, 0.1, 1);
  }
  .in-view.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script is:inline>
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          io.unobserve(entry.target);
        }
      });
    },
    { rootMargin: "0px 0px -80px 0px", threshold: 0.05 }
  );
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".in-view").forEach((el) => io.observe(el));
  });
</script>
