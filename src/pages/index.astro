---
import Layout from "../layouts/Layout.astro";
import Theme from "../components/Theme.astro";
import Presentation from "../components/Presentation.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Skills from "../components/Skills.astro";
import Experience from "../components/Experience.astro";
import About from "../components/About.astro";
import Projects from "../components/Projects.astro";

const links = [
  { href: "https://github.com/alexisabels", icon: "GithubIcon", alt: "GitHub" },
  {
    href: "https://linkedin.com/in/alexisabel",
    icon: "LinkedInIcon",
    alt: "LinkedIn",
  },
  { href: "mailto:isabelsanchezalex@gmail.com", icon: "MailIcon", alt: "Email" },
  { href: "/AlejandroIsabelCV.pdf", icon: "CVIcon", alt: "CV" },
];

const YEAR = new Date().getFullYear();
---

<Layout title="Alejandro Isabel — Desarrollador de software">
  <Theme />

  <main class="w-full max-w-[1240px] mx-auto">
    <Presentation
      name="Alejandro Isabel"
      location="Toledo"
      imageUrl="/nueva.png"
      links={links}
    />

    <section class="in-view pb-24 md:pb-32">
      <SectionHeading title="Sobre mí" />
      <About />
    </section>

    <section class="in-view pb-24 md:pb-32">
      <SectionHeading title="Experiencia" />
      <Experience />
    </section>

    <section class="in-view pb-24 md:pb-32">
      <SectionHeading title="Stack" />
      <Skills />
    </section>

    <section class="in-view pb-24 md:pb-32">
      <SectionHeading title="Proyectos" />
      <Projects />
    </section>

    <footer
      class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4 border-t border-hairline py-8 md:py-10 text-sm text-ink-muted"
    >
      <span>© {YEAR} Alejandro Isabel</span>
      <span>Toledo, España</span>
    </footer>
  </main>
</Layout>
